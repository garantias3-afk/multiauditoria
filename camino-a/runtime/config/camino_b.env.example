# Camino B local Gateway and subscription agent
CAMINO_B_QUEUE_ROOT=/absolute/path/to/camino-b-slot14-queue
CAMINO_B_RUNS_ROOT=/absolute/path/to/operational_runs
CAMINO_B_GATEWAY_API_KEY=***
CAMINO_B_GATEWAY_HOST=127.0.0.1
CAMINO_B_GATEWAY_PORT=8787

# Optional direct TLS termination. Prefer a managed HTTPS reverse proxy/tunnel.
CAMINO_B_TLS_CERT=
CAMINO_B_TLS_KEY=

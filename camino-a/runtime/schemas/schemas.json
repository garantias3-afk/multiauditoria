{
  "output_manifest.schema.json": {
    "type": "object",
    "required": [
      "schema_version",
      "run_id",
      "stage",
      "candidate_sha256",
      "files",
      "created_at_utc"
    ],
    "properties": {
      "schema_version": {
        "const": "camino_a_output_manifest.v1"
      },
      "run_id": {
        "type": "string"
      },
      "stage": {
        "type": "string"
      },
      "candidate_sha256": {
        "type": "string",
        "pattern": "^[a-f0-9]{64}$"
      },
      "created_at_utc": {
        "type": "string"
      },
      "files": {
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "path",
            "sha256",
            "size_bytes"
          ],
          "properties": {
            "path": {
              "type": "string"
            },
            "sha256": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            },
            "size_bytes": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    }
  },
  "run_state.schema.json": {
    "type": "object",
    "required": [
      "run_id",
      "run_dir"
    ],
    "properties": {
      "run_id": {
        "type": "string"
      },
      "run_dir": {
        "type": "string"
      },
      "current_phase": {
        "type": "string"
      },
      "candidate_sha256": {
        "type": "string"
      },
      "current_candidate_sha256": {
        "type": "string"
      },
      "iteration_number": {
        "type": "integer"
      },
      "current_slot": {
        "type": ["string", "null"],
        "pattern": "^(?:[1-9]|1[0-4])$"
      },
      "completed_slots": {
        "type": "array",
        "items": {"type": ["string", "integer"]},
        "uniqueItems": true
      },
      "execution_context": {
        "type": "object"
      },
      "updated_at": {
        "type": "string"
      }
    }
  },
  "worker_result.schema.json": {
    "type": "object",
    "required": [
      "worker_id",
      "job_id",
      "run_id",
      "slot_id",
      "candidate_sha256",
      "status",
      "summary"
    ],
    "properties": {
      "worker_id": {
        "type": "string"
      },
      "job_id": {
        "type": "string"
      },
      "run_id": {
        "type": "string"
      },
      "status": {
        "enum": [
          "ok",
          "bug_found",
          "patch_proposed",
          "failed",
          "timeout",
          "quota_limited",
          "completed",
          "insufficient_evidence",
          "auth_missing",
          "worker_missing",
          "unavailable",
          "deferred"
        ]
      },
      "summary": {
        "type": "string"
      },
      "artifacts": {
        "type": "array"
      },
      "slot_id": {
        "type": "string",
        "pattern": "^(?:[1-9]|1[0-4]|NO_CONSTA)$"
      },
      "candidate_sha256": {
        "type": "string",
        "pattern": "^[a-f0-9]{64}$"
      },
      "verdict": {
        "type": "string"
      },
      "corrections_applied": {
        "type": "boolean"
      },
      "candidate_update": {
        "$ref": "candidate_update.schema.json"
      }
    }
  },
  "candidate_update.schema.json": {
    "type": "object",
    "required": [
      "schema_version",
      "source_candidate_sha256",
      "candidate_sha256",
      "archive_path",
      "archive_sha256",
      "file_count",
      "total_bytes",
      "worker_id",
      "slot_id"
    ],
    "properties": {
      "schema_version": {"const": "camino_candidate_update.v1"},
      "source_candidate_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
      "candidate_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
      "archive_path": {"const": "candidate_update.zip"},
      "archive_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
      "file_count": {"type": "integer", "minimum": 1},
      "total_bytes": {"type": "integer", "minimum": 0},
      "worker_id": {"type": "string", "minLength": 1},
      "slot_id": {"type": "string", "pattern": "^(?:[1-9]|1[0-4])$"}
    },
    "additionalProperties": false
  },
  "quality_delta.schema.json": {
    "type": "object",
    "required": [
      "schema_version",
      "entry_id",
      "created_at_utc",
      "run_id",
      "auditor",
      "finding",
      "adjudication"
    ],
    "properties": {
      "schema_version": {
        "const": "ai_quality_log_entry.v1"
      },
      "entry_id": {
        "type": "string"
      },
      "created_at_utc": {
        "type": "string"
      },
      "run_id": {
        "type": "string"
      },
      "audit_family": {
        "type": "string"
      },
      "artifact": {
        "type": "object"
      },
      "auditor": {
        "type": "object",
        "required": [
          "slot_id",
          "route_id",
          "model_id",
          "provider_id",
          "provider_name",
          "route",
          "interface",
          "cost_class",
          "role",
          "worker_id"
        ],
        "properties": {
          "slot_id": {
            "type": "string"
          },
          "route_id": {
            "type": "string"
          },
          "model_id": {
            "type": "string"
          },
          "provider_id": {
            "type": "string"
          },
          "provider_name": {
            "type": "string"
          },
          "route": {
            "type": "string"
          },
          "interface": {
            "type": "string"
          },
          "cost_class": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "worker_id": {
            "type": "string"
          }
        },
        "additionalProperties": true
      },
      "finding": {
        "type": "object",
        "required": [
          "id",
          "type",
          "severity",
          "summary"
        ],
        "additionalProperties": true
      },
      "adjudication": {
        "type": "object",
        "required": [
          "final_status"
        ],
        "additionalProperties": true
      }
    }
  },
  "quality_log_runtime.schema.json": {
    "type": "object",
    "required": [
      "quality_log_required",
      "delta_dir",
      "sqlite_table"
    ],
    "properties": {
      "quality_log_required": {
        "const": true
      },
      "delta_dir": {
        "const": "90_QUALITY_LOG_DELTA"
      },
      "sqlite_table": {
        "const": "quality_log"
      }
    }
  },
  "host_runtime_report.schema.json": {
    "type": "object",
    "required": ["schema_version", "host", "lmstudio", "drive", "peer"],
    "properties": {
      "schema_version": {"const": "camino_host_runtime_report.v1"},
      "host": {
        "type": "object",
        "required": ["hostname", "role", "architecture_family", "memory"]
      },
      "lmstudio": {"type": "object"},
      "drive": {"type": "object"},
      "peer": {"type": "object"}
    }
  },
  "manual_submission.schema.json": {
    "type": "object",
    "required": ["schema_version", "submission_id", "run_id", "worker_id", "candidate_sha256", "items"],
    "properties": {
      "schema_version": {"const": "camino_a_manual_submission.v2"},
      "submission_id": {"type": "string"},
      "run_id": {"type": "string"},
      "worker_id": {"enum": ["manual_gpt", "manual_claude"]},
      "candidate_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
      "slot_id": {"type": "string", "pattern": "^(?:[1-9]|1[0-4])$"},
      "items": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "required": ["stored_name", "mime_type", "size_bytes", "sha256", "role"]
        }
      }
    }
  }
}
